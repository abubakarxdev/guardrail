# =========================
# GuardRail .gitignore
# =========================

# -------------------------
# Global / OS
# -------------------------
.DS_Store
Thumbs.db
*.swp
*~
.vscode/
.idea/

# -------------------------
# Backend (Python / FastAPI)
# -------------------------
backend/venv/
backend/env/
backend/.env
backend/__pycache__/
backend/*.py[cod]
backend/*$py.class
backend/.pytest_cache/
backend/alembic.ini
backend/guardrail_db.db
backend/guardrail_db.sqlite
backend/guardrail_db.sqlite3
*.db
*.sqlite
*.sqlite3

# Celery & Redis
celerybeat-schedule
*.pid

# -------------------------
# Frontend (Next.js / React)
# -------------------------
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.vercel/

# -------------------------
# Logs & Temp files
# -------------------------
*.log
tmp/
temp/
